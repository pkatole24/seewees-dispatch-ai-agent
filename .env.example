OPENAI_API_KEY=

# Optional email delivery. Leave blank to skip email sending.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=

# Optional LangSmith tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=MSBA_AI_Agents_Demo
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Optional weather fallback when waypoint retrieval is unavailable
WEATHER_LAT=40.7282
WEATHER_LON=-74.0776
WEATHER_TZ=America/New_York

# Optional graph behavior
AUDIT_MAX_RETRIES=2
